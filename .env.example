APP_ENV=development
APP_VERSION=0.1.0
APP_PORT=8080

# Redis
REDIS_HOST=redis
REDIS_PORT=6379
REDIS_PASSWORD=
REDIS_DB=0
REDIS_DIAL_TIMEOUT=5s
REDIS_READ_TIMEOUT=3s
REDIS_WRITE_TIMEOUT=3s
REDIS_POOL_SIZE=10
REDIS_MIN_IDLE_CONNS=5
REDIS_POOL_TIMEOUT=4s
REDIS_CONN_MAX_IDLE_TIME=5m
REDIS_CONN_MAX_LIFETIME=30m

# RabbitMQ
RABBITMQ_HOST=rabbitmq
RABBITMQ_USER=dante
RABBITMQ_PASS=dante_password
RABBITMQ_DIAL_TIMEOUT=3s
AMQP_RABBITMQ_PORT=5672
WEBUI_RABBITMQ_PORT=15672
RABBITMQ_QRIS_PAYMENTS_QUEUE=dante.qris.payments
RABBITMQ_TRANSFERS_QUEUE=dante.transfers
RABBITMQ_MAX_RETRY_ATTEMPTS=3
RABBITMQ_RETRY_BASE_DELAY=2s
RABBITMQ_QRIS_WORKERS=1
RABBITMQ_TRANSFER_WORKERS=1
RABBITMQ_PREFETCH_COUNT=1

# PostgreSQL
DB_HOST=db
DB_HOST_EXTERNAL=localhost
DB_PORT=5432
DB_PORT_EXTERNAL=5432
DB_USER=postgres
DB_PASS=dante_password
DB_NAME=dante
DB_SSLMODE=disable
DB_MAX_OPEN_CONNS=25
DB_MAX_IDLE_CONNS=25
DB_CONN_MAX_IDLE_TIME=5m

# Legacy SOAP
LEGACY_BANKSERVICE_URL=http://host.docker.internal:8081/axis2/services/BankService
LEGACY_TIMEOUT=5s

# Observability
TRACING_ENABLED=true
JAEGER_OTLP_ENDPOINT=jaeger:4318
OTEL_SERVICE_NAME=dante-api-systems
TRACE_SAMPLE_RATIO=1.0

# Grafana
GRAFANA_ADMIN_USER=admin
GRAFANA_ADMIN_PASSWORD=admin
DB_CONN_MAX_LIFETIME=30m
